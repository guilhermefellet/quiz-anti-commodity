# WhatsApp da Ana (público, exposto no client pra construir o link)
NEXT_PUBLIC_WHATSAPP_NUMBER=5521920122976

# Webhook do Make.com (server-side, NÃO expor no client)
# Crie um cenário no Make com "Webhooks > Custom webhook", copie a URL e cole aqui.
# Se ficar vazio, o quiz continua funcionando e só persiste em data/submissions.json.
MAKE_WEBHOOK_URL=

# Meta Pixel ID (público, exposto no client). Sem ele, o Pixel não carrega.
NEXT_PUBLIC_META_PIXEL_ID=

# Conversion API token (server-side, NUNCA expor no client). Gere em
# Events Manager > Settings > Conversions API > Generate access token.
# Sem ele, eventos server-side (Lead, Contact via API) ficam desativados.
META_CAPI_ACCESS_TOKEN=

# Test Event Code (server-side, opcional). Quando preenchido, todo evento
# enviado ao CAPI vira "test" e aparece na aba Test Events do Events Manager.
# Use só enquanto valida e REMOVA antes de escalar tráfego em produção.
META_CAPI_TEST_EVENT_CODE=
